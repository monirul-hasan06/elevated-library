# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_EMAIL=dev.get.in.touch@gmail.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Storage
STORAGE_PROVIDER=supabase
SUPABASE_STORAGE_BUCKET=elevated-library-pdfs

# Cloudflare R2 (optional, leave empty if using Supabase Storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=elevated-library-pdfs
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com

# Email
RESEND_API_KEY=
EMAIL_FROM=Elevated Library <onboarding@resend.dev>

# Security
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=change_this_to_a_long_random_secret_min_16_chars
CRON_SECRET=change_this_to_a_long_random_secret_min_16_chars
